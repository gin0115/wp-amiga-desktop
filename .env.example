# WordPress REST base URL. Defaults to the bundled mock fixtures so the
# dev server boots fully populated with zero config. Point this at a real
# WP site (e.g. https://example.com/wp-json) for production / live data.
VITE_WP_BASE_URL=./mocks/wp-json

# Kickstart ROM URL. Required for the SAE emulator to boot. Use a free
# AROS Kickstart replacement (e.g. https://aros.sourceforge.io/). Without
# this set, clicking Power surfaces a clear "ROM not configured" message.
# Bundle locally as /roms/aros-kickstart.rom or host on a CDN.
VITE_KICKSTART_URL=

# Kickstart extension ROM (e.g. aros-ext.bin alongside aros-rom.bin).
# AROS m68k needs this to actually boot the display — without it the
# main Kickstart loads but renders a black screen.
VITE_KICKSTART_EXT_URL=

# AROS Workbench hardfile (HDF) URL. Optional. Too large to bundle
# (~20-50MB) so it lives on a CDN. Mounts as DH0:. Without this the
# emulator boots Kickstart only.
VITE_HDF_URL=
