# WordPress REST base URL. Defaults to the bundled mock fixtures so the
# dev server boots fully populated with zero config. Point this at a real
# WP site (e.g. https://example.com/wp-json) for production / live data.
VITE_WP_BASE_URL=/mocks/wp-json

# AROS Workbench hardfile (HDF) URL. Too large to bundle (~20-50MB) so it
# lives on a CDN. Fetched at runtime when the user clicks Power on the
# back screen. Leave unset to disable the emulator entirely.
VITE_HDF_URL=
